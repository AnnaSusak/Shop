@model Product
<h1 class="font-weight-light font-italic text-uppercase">Delete Product</h1>
<form method="post" asp-action="DeletePost">
    <!--предача скрытых данных-->
    <input asp-for="Id" hidden />
    <p>
        <label class="fst-italic" asp-for="Name"></label>
        <input disabled class="form-control form-control-lg" asp-for="Name" />

    </p>
    <p>
        <label class="fst-italic" asp-for="Price"></label>
        <input disabled class="form-control form-control-lg" type="number" asp-for="Price" />

    </p>
    <p>
        <label class="fst-italic" asp-for="Description"></label>
        <textarea asp-for="Description" class="summernote form-control form-control-lg" disabled></textarea>
    </p>
    <p>
        <label class="fst-italic" asp-for="CategoryId"></label>
        <input asp-for="Category.Name" class="form-control" disabled />
    </p>
    <p>
        <label class="fst-italic" asp-for="MyModelId"></label>
        <input asp-for="MyModel.Name" class="form-control" disabled/>
    </p>
    <p>
        <button type="submit" class="btn btn-danger">
            <i class="fa-sharp fa-solid fa-trash"></i>
        </button>

        <a asp-controller="Product" asp-action="Index" class="btn bg-dark text-light font-weight-bold"><i class="fa-solid fa-chevron-left"></i></a>
    </p>
</form>

@section Scripts{

    <script>
        /*editor*/
        $(document).ready(function () {
            $('.summernote').summernote(
                {
                    height: 200,
                    disabled: true
                }
            );
        });
    </script>
}
